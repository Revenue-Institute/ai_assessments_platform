# Spec §16 environment variables. Copy to .env.local and fill in.

APP_ENV=local

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
DATABASE_URL=

JWT_SIGNING_SECRET=
SESSION_COOKIE_SECRET=

ANTHROPIC_API_KEY_GENERATION=
ANTHROPIC_API_KEY_SCORING=

E2B_API_KEY=

N8N_HOST=
N8N_ADMIN_API_KEY=
N8N_WEBHOOK_SECRET=

UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

RESEND_API_KEY=
RESEND_FROM_EMAIL=assessments@revenueinstitute.com
# HMAC secret used to verify Resend delivery webhooks (POST /webhooks/resend).
# Generate via `openssl rand -hex 32` and paste the same value into the Resend
# dashboard's webhook signing-secret field.
RESEND_WEBHOOK_SECRET=

VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIMS=1024

SENTRY_DSN_API=
AXIOM_TOKEN=
AXIOM_DATASET=

SUPABASE_STORAGE_BUCKET_ARTIFACTS=ri-artifacts
SUPABASE_STORAGE_BUCKET_REFERENCES=ri-references

NEXT_PUBLIC_ADMIN_URL=http://localhost:3000
NEXT_PUBLIC_CANDIDATE_URL=http://localhost:3001
INTERNAL_API_URL=http://localhost:8000
