{
  "name": "api",
  "private": true,
  "scripts": {
    "dev": "uv run uvicorn ri_assessments_api.main:app --reload --port 8000",
    "start": "uv run uvicorn ri_assessments_api.main:app --host 0.0.0.0 --port 8000",
    "test": "uv run pytest",
    "lint": "uv run ruff check src tests",
    "fmt": "uv run ruff format src tests",
    "typecheck": "uv run python -c 'import ri_assessments_api'",
    "gen-schemas": "uv run python scripts/gen_schemas.py",
    "migrate": "uv run python scripts/apply_migrations.py",
    "seed": "uv run python scripts/seed_test_assignment.py",
    "clean": "git clean -xdf .cache .turbo dist node_modules .venv"
  }
}
