# Spec §16. Copy to .env.local and fill in.

# Server
INTERNAL_API_URL="http://localhost:8000"

# Observability (optional locally). Spec §15/§16 requires three Sentry
# projects: admin, candidate, api. Candidate reads its own DSN below.
#
# NEXT_PUBLIC_SENTRY_DSN_CANDIDATE: from the candidate project's
#   "Client Keys (DSN)" page in Sentry
#   (Settings > Projects > ri-candidate > Client Keys).
# NEXT_PUBLIC_SENTRY_DSN: legacy shared DSN; leave blank once the
#   per-app DSN above is set.
# SENTRY_ORG / SENTRY_PROJECT_CANDIDATE: Sentry org slug + candidate
#   project slug. SENTRY_PROJECT remains the legacy fallback.
# SENTRY_AUTH_TOKEN: required at BUILD time to upload source maps.
#   Generate at Sentry > User Settings > Auth Tokens with the
#   `project:releases` scope.
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_PROJECT_CANDIDATE=""
SENTRY_AUTH_TOKEN=""

# Client
NEXT_PUBLIC_API_URL="http://localhost:8000"
NEXT_PUBLIC_CANDIDATE_URL="http://localhost:3001"
# Required ONLY when this candidate deployment is served behind the
# admin's /a/* rewrite (single-host prod). Set to the candidate's own
# absolute origin (e.g. https://candidate-prod.vercel.app) so chunks
# load from candidate, not from admin. Leave unset in dev.
NEXT_PUBLIC_CANDIDATE_ASSET_ORIGIN=""
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN_CANDIDATE=""
