# Spec §16. Copy to .env.local and fill in.

# Server
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
INTERNAL_API_URL="http://localhost:8000"

# Observability (optional locally). Spec §15/§16 requires three Sentry
# projects: admin, candidate, api. Admin reads its own DSN below.
#
# NEXT_PUBLIC_SENTRY_DSN_ADMIN: from Sentry, the admin project's
#   "Client Keys (DSN)" page (Settings > Projects > ri-admin > Client Keys).
# NEXT_PUBLIC_SENTRY_DSN: legacy shared DSN, kept for back-compat. Leave
#   blank once the per-app DSN above is set.
# SENTRY_ORG / SENTRY_PROJECT_ADMIN: Sentry org slug + admin project slug
#   (Settings > Projects > ri-admin > URL slug). SENTRY_PROJECT below is
#   the legacy single-project fallback.
# SENTRY_AUTH_TOKEN: required at BUILD time to upload source maps.
#   Generate at Sentry > User Settings > Auth Tokens with the
#   `project:releases` scope. Set in CI / Vercel project env, not in
#   committed files.
BETTERSTACK_API_KEY=""
BETTERSTACK_URL=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_PROJECT_ADMIN=""
SENTRY_AUTH_TOKEN=""

# Client
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
NEXT_PUBLIC_ADMIN_URL="http://localhost:3000"
NEXT_PUBLIC_CANDIDATE_URL="http://localhost:3001"
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN_ADMIN=""
