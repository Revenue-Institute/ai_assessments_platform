# Revenue Institute Assessments Platform: consolidated env vars (spec §16).
#
# Copy this file to .env (gitignored) and fill in. The per-app
# .env.example files (apps/api/.env.example, apps/admin/.env.example) are
# subsets that pick the variables each app actually reads; keep them in
# sync if you add new variables here.

###############################################################################
# Environment
###############################################################################
APP_ENV=local                       # local | staging | production
NODE_ENV=development

###############################################################################
# Supabase
###############################################################################
SUPABASE_URL=                       # https://<ref>.supabase.co
SUPABASE_ANON_KEY=                  # candidate app + admin client
SUPABASE_SERVICE_ROLE_KEY=          # api + admin server (bypasses RLS)
SUPABASE_JWT_SECRET=                # used by FastAPI to verify admin JWTs
DATABASE_URL=                       # postgresql://postgres:...@db.<ref>.supabase.co:5432/postgres

# Convenience for the candidate + admin Next.js apps
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

###############################################################################
# Auth (FastAPI signs candidate magic links with this)
###############################################################################
JWT_SIGNING_SECRET=                 # 32+ random chars
SESSION_COOKIE_SECRET=              # 32+ random chars (admin Next.js)

###############################################################################
# Anthropic (separate keys for cost attribution per spec §15)
###############################################################################
ANTHROPIC_API_KEY_GENERATION=
ANTHROPIC_API_KEY_SCORING=

###############################################################################
# E2B (code / sql / notebook sandboxes)
###############################################################################
E2B_API_KEY=

###############################################################################
# n8n (self-hosted)
###############################################################################
N8N_HOST=                           # https://n8n-<project>.run.app
N8N_ADMIN_API_KEY=                  # personal API key from n8n Settings → API
N8N_WEBHOOK_SECRET=                 # for inbound webhook validation (optional v1)

###############################################################################
# Redis (BullMQ when async scoring lands)
###############################################################################
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

###############################################################################
# Email
###############################################################################
RESEND_API_KEY=
RESEND_FROM_EMAIL=assessments@revenueinstitute.com
RESEND_WEBHOOK_SECRET=               # HMAC secret for POST /webhooks/resend

###############################################################################
# Embeddings
# v1 uses OpenAI text-embedding-3-small with the `dimensions` parameter
# truncating to 1024 (Matryoshka). The reference_chunks.embedding column
# is sized for 1024 in migration 0004; if you switch providers you must
# also alter the column to match. Spec §19 originally defaulted to
# Voyage-3 (1024 dims); we picked OpenAI for ops familiarity. Flip
# providers in services/references.py if Voyage becomes preferred.
###############################################################################
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMS=1024

###############################################################################
# Observability
###############################################################################
SENTRY_DSN_ADMIN=
SENTRY_DSN_CANDIDATE=
SENTRY_DSN_API=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
AXIOM_TOKEN=
AXIOM_DATASET=
BETTERSTACK_API_KEY=
BETTERSTACK_URL=

###############################################################################
# Storage
###############################################################################
SUPABASE_STORAGE_BUCKET_ARTIFACTS=ri-artifacts
SUPABASE_STORAGE_BUCKET_REFERENCES=ri-references

###############################################################################
# App URLs
###############################################################################
NEXT_PUBLIC_ADMIN_URL=http://localhost:3000
NEXT_PUBLIC_CANDIDATE_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://localhost:8000
